{
  "name": "payment-service",
  "version": "1.0.0",
  "scripts": {
    "test:pact": "jest --testPathPattern=pact",
    "test:pact:broker": "cross-env PACT_BROKER_BASE_URL=http://localhost:9292 PACT_BROKER_USERNAME=pact_user PACT_BROKER_PASSWORD=pact_password CI=true jest --testPathPattern=pact",
    "can-i-deploy": "node scripts/pact-broker.js can-i-deploy",
    "record-deployment": "node scripts/pact-broker.js record-deployment"
  },
  "dependencies": {
    "express": "^4.18.0"
  },
  "devDependencies": {
    "@pact-foundation/pact": "^16.3.0",
    "@pact-foundation/pact-cli": "^16.0.0",
    "@types/express": "^4.17.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "cross-env": "^10.1.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testTimeout": 60000
  }
